# Copy to .env (or export directly) for local runs.

# Required: PostgreSQL connection string (pgx / libpq format).
#
# WARNING: sslmode=disable is for LOCAL DEVELOPMENT ONLY — it sends calendar
# data (PII) and the DB password in cleartext. For any non-loopback database,
# use an encrypting, certificate-verifying mode and a unique password:
#   postgres://medav:<strong-unique-pw>@db.example.com:5432/medav?sslmode=verify-full&sslrootcert=/path/ca.crt
DATABASE_URL=postgres://medav:medav@localhost:5432/medav?sslmode=disable

# Optional: HTTP listen address. Default "127.0.0.1:8080" (loopback only).
# medav performs NO authentication of its own. Keep it on loopback so only a
# colocated reverse proxy can reach it, or bind elsewhere ONLY together with
# PROXY_AUTH_SECRET below. Binding to ":8080"/"0.0.0.0:..." exposes an
# unauthenticated server to the network.
LISTEN_ADDR=127.0.0.1:8080

# Optional: enforce that requests transited the trusted upstream proxy. When
# PROXY_AUTH_SECRET is set, every request (except /healthz) must carry the
# header named by PROXY_AUTH_HEADER with this exact value, else it is rejected
# with 403. Configure the proxy to inject that header. Leave empty only when a
# loopback bind already isolates the service.
PROXY_AUTH_HEADER=X-Medav-Proxy-Auth
PROXY_AUTH_SECRET=

# Optional: maximum request body size in bytes. Default 10485760 (10 MiB).
# Set to 0 to disable the limit (not recommended).
MAX_BODY_BYTES=10485760

# Optional: maximum number of calendars (caps MKCALENDAR creation). Default 100.
# Set to 0 to disable the cap.
MAX_CALENDARS=100

# Optional: URL path prefix the CalDAV handler is mounted under (no trailing
# slash). Leave empty to mount at the root. Keep this STABLE once data exists:
# stored object paths include the prefix, so changing it invalidates them.
PREFIX=

# Optional: log level — debug | info | warn | error. Default "info".
LOG_LEVEL=info
