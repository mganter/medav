# Copy to .env (or export directly) for local runs.

# Required: PostgreSQL connection string (pgx / libpq format).
DATABASE_URL=postgres://medav:medav@localhost:5432/medav?sslmode=disable

# Optional: HTTP listen address. Default ":8080".
LISTEN_ADDR=:8080

# Optional: URL path prefix the CalDAV handler is mounted under (no trailing
# slash). Leave empty to mount at the root. Keep this STABLE once data exists:
# stored object paths include the prefix, so changing it invalidates them.
PREFIX=

# Optional: log level — debug | info | warn | error. Default "info".
LOG_LEVEL=info
